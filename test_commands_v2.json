[
  {"comment": "=== Part A: Effect Plugin (original commands + lifecycle) ==="},

  {"action": "load_plugin",
   "plugin_path": "build/TestGainPlugin_artefacts/Release/VST3/Test Gain Plugin.vst3"},

  {"action": "get_plugin_info"},

  {"action": "list_parameters"},

  {"action": "set_parameter", "parameter_id": "gain", "value": 0.5},
  {"action": "set_parameter", "parameter_id": "frequency", "value": 0.7},

  {"action": "generate_and_process", "signal_type": "sine", "frequency": 440.0,
   "duration_ms": 200, "sample_rate": 44100, "amplitude": 0.8},

  {"action": "generate_and_process", "signal_type": "impulse",
   "duration_ms": 100, "sample_rate": 44100},

  {"action": "generate_and_process", "signal_type": "sweep",
   "duration_ms": 500, "sample_rate": 44100, "frequency": 20.0, "end_frequency": 20000.0},

  {"action": "analyze_output", "include_spectrum": true, "fft_order": 12, "max_peaks": 5},

  {"comment": "--- Editor open/close on effect plugin ---"},
  {"action": "open_editor"},
  {"action": "capture_ui", "output_path": "/tmp/effect_ui.png"},
  {"action": "get_parameter_layout"},
  {"action": "close_editor"},

  {"comment": "--- Editor lifecycle stress test (10 rapid open/close) ---"},
  {"action": "test_editor_lifecycle", "iterations": 10},

  {"comment": "--- Plugin lifecycle stress test (5 load/unload cycles) ---"},
  {"action": "test_plugin_lifecycle",
   "plugin_path": "build/TestGainPlugin_artefacts/Release/VST3/Test Gain Plugin.vst3",
   "iterations": 5},


  {"comment": "=== Part B: Synth Plugin ==="},

  {"action": "load_plugin",
   "plugin_path": "build/TestSynthPlugin_artefacts/Release/VST3/Test Synth Plugin.vst3"},

  {"action": "get_plugin_info"},

  {"action": "list_parameters"},

  {"comment": "--- Convenience: render a single A4 note (sine, defaults) ---"},
  {"action": "render_synth_note",
   "midi_note": 69, "velocity": 100,
   "duration_ms": 500, "sample_rate": 44100},

  {"comment": "--- Low-level MIDI: polyphonic C-major chord ---"},
  {"action": "send_midi_and_process",
   "duration_ms": 600,
   "sample_rate": 44100,
   "midi_events": [
     {"type": "note_on",  "note": 60, "velocity": 100, "time_ms": 0},
     {"type": "note_on",  "note": 64, "velocity": 90,  "time_ms": 0},
     {"type": "note_on",  "note": 67, "velocity": 80,  "time_ms": 0},
     {"type": "note_off", "note": 60, "velocity": 0,   "time_ms": 400},
     {"type": "note_off", "note": 64, "velocity": 0,   "time_ms": 400},
     {"type": "note_off", "note": 67, "velocity": 0,   "time_ms": 400}
   ]},

  {"comment": "--- CC automation during note ---"},
  {"action": "send_midi_and_process",
   "duration_ms": 500,
   "sample_rate": 44100,
   "midi_events": [
     {"type": "note_on",  "note": 72, "velocity": 100, "time_ms": 0},
     {"type": "cc", "controller": 1,  "value": 64,     "time_ms": 100},
     {"type": "cc", "controller": 1,  "value": 127,    "time_ms": 200},
     {"type": "note_off", "note": 72, "velocity": 0,   "time_ms": 350}
   ]},

  {"comment": "--- Synth editor ---"},
  {"action": "open_editor"},
  {"action": "capture_ui", "output_path": "/tmp/synth_ui.png"},
  {"action": "get_parameter_layout"},
  {"action": "close_editor"},

  {"comment": "--- Synth editor lifecycle stress (10 cycles) ---"},
  {"action": "test_editor_lifecycle", "iterations": 10},

  {"comment": "--- Synth plugin lifecycle stress (3 cycles) ---"},
  {"action": "test_plugin_lifecycle",
   "plugin_path": "build/TestSynthPlugin_artefacts/Release/VST3/Test Synth Plugin.vst3",
   "iterations": 3}
]
